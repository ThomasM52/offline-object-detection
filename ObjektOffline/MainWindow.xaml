<Window x:Class="ObjektOffline.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Offline Object Detection (ML.NET)"
        Height="750"
        Width="1100"
        Background="#1E1E1E"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Background="#2D2D30" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <DockPanel>
                <TextBlock Text="Offline Object Detection - ML.NET"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="White"
                           DockPanel.Dock="Left"/>

                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <Button Content="Vælg billede"
                            Width="130"
                            Margin="0,0,10,0"
                            Padding="8,4"
                            Click="SelectImage_Click"/>

                    <Button Content="Predict"
                            Width="130"
                            Padding="8,4"
                            Click="Predict_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="1.3*"/>
            </Grid.ColumnDefinitions>

            <!-- IMAGE AREA -->
            <Border Grid.Column="0"
                    Background="#252526"
                    CornerRadius="8"
                    Padding="10"
                    Margin="0,0,15,0">

                <Grid>
                    <Image x:Name="MainImage"
                           Stretch="Uniform"/>

                    <Canvas x:Name="OverlayCanvas"
                            IsHitTestVisible="False"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"/>
                </Grid>
            </Border>

            <!-- SIDE PANEL -->
            <Border Grid.Column="1"
                    Background="#252526"
                    CornerRadius="8"
                    Padding="15">

                <StackPanel>
                    <TextBlock Text="Predictions"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="White"
                               Margin="0,0,0,15"/>

                    <ListBox x:Name="PredictionsList"
                             Background="#1E1E1E"
                             Foreground="White"
                             BorderThickness="0"
                             FontSize="14"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- CONFIDENCE SLIDER -->
        <Border Grid.Row="2"
                Background="#2D2D30"
                CornerRadius="8"
                Padding="15"
                Margin="0,15,0,0">

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Confidence threshold:"
                           Foreground="White"
                           FontSize="14"
                           VerticalAlignment="Center"
                           Margin="0,0,15,0"/>

                <Slider x:Name="ConfidenceSlider"
                        Minimum="0"
                        Maximum="1"
                        Value="0.9"
                        Width="250"
                        TickFrequency="0.01"
                        IsSnapToTickEnabled="True"
                        ValueChanged="ConfidenceSlider_ValueChanged"/>

                <TextBlock Text="{Binding ElementName=ConfidenceSlider, Path=Value, StringFormat=F2}"
                           Foreground="White"
                           FontSize="14"
                           Margin="15,0,0,0"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

    </Grid>
</Window>